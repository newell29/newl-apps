# Runtime
NODE_ENV=development
APP_URL=http://localhost:3000
DEFAULT_TENANT_SLUG=newl-group

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Auth / Session
AUTH_SECRET=AUTH_SECRET_PLACEHOLDER

# OpenAI
OPENAI_API_KEY=OPENAI_API_KEY_PLACEHOLDER

# Apollo
APOLLO_API_KEY=APOLLO_API_KEY_PLACEHOLDER
APOLLO_MASTER_API=APOLLO_MASTER_API_PLACEHOLDER
APOLLO_USERNAME=APOLLO_USERNAME_PLACEHOLDER
APOLLO_PASSWORD=APOLLO_PASSWORD_PLACEHOLDER
APOLLO_PUBLIC_CONFIG_EXAMPLE={"baseUrl":"https://api.apollo.io","dryRun":true}

# TradeMining
TRADEMINING_USER=TRADEMINING_USER_PLACEHOLDER
TRADEMINING_PASSWORD=TRADEMINING_PASSWORD_PLACEHOLDER
TRADEMINING_PUBLIC_CONFIG_EXAMPLE={"lookbackDays":7,"ports":["PORT_KEY_PLACEHOLDER"]}

# Google Sheets legacy migration/export
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-service-account.json
NEWL_TRADE_MINING_SPREADSHEET_ID=GOOGLE_SHEETS_ID_PLACEHOLDER
NEWL_PROSPECTING_SHEET_ID=GOOGLE_SHEETS_ID_PLACEHOLDER
GOOGLE_SHEETS_PUBLIC_CONFIG_EXAMPLE={"spreadsheetId":"GOOGLE_SHEETS_ID_PLACEHOLDER","exportOnly":true}

# QuickBooks future module
QUICKBOOKS_CLIENT_ID=QUICKBOOKS_CLIENT_ID_PLACEHOLDER
QUICKBOOKS_CLIENT_SECRET=QUICKBOOKS_CLIENT_SECRET_PLACEHOLDER
QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback

# UPS future module
UPS_CLIENT_ID=UPS_CLIENT_ID_PLACEHOLDER
UPS_CLIENT_SECRET=UPS_CLIENT_SECRET_PLACEHOLDER
UPS_ACCOUNT_NUMBER=UPS_ACCOUNT_NUMBER_PLACEHOLDER

# OpenClaw / legacy operations reporting
OPENCLAW_TOKEN=OPENCLAW_TOKEN_PLACEHOLDER
OPENCLAW_AGENT_RUN_TOKEN=OPENCLAW_AGENT_RUN_TOKEN_PLACEHOLDER

# Newl Apps ingestion API for VM/OpenClaw/n8n workers
# Use a long random value locally or in the deployment secret store. Do not commit real tokens.
INGESTION_API_TOKEN=INGESTION_API_TOKEN_PLACEHOLDER_CHANGE_ME
INGESTION_TENANT_SLUG=newl-group

# n8n legacy reference
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=N8N_API_KEY_PLACEHOLDER
