# Runtime
NODE_ENV=development
APP_URL=http://localhost:3000
DEFAULT_TENANT_SLUG=newl-group

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Auth / Session (Auth.js v5 / next-auth)
# Generate a strong value locally with: npx auth secret
AUTH_SECRET=AUTH_SECRET_PLACEHOLDER
# Public base URL of the app. Used by Auth.js for callback URLs.
AUTH_URL=http://localhost:3000
# Trust the incoming host header (needed for some self-hosted/proxied setups).
AUTH_TRUST_HOST=true
# Database session lifetime in days (defaults to 30 when unset).
SESSION_MAX_AGE_DAYS=30

# Microsoft Entra ID (Azure AD) SSO - PRODUCTION login.
# Real values are provisioned per environment and MUST NOT be committed.
# Auth.js-native variable names:
AUTH_MICROSOFT_ENTRA_ID_ID=AZURE_AD_CLIENT_ID_PLACEHOLDER
AUTH_MICROSOFT_ENTRA_ID_SECRET=AZURE_AD_CLIENT_SECRET_PLACEHOLDER
# Issuer for a single-tenant app (recommended). Replace <tenant-id>:
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/AZURE_AD_TENANT_ID_PLACEHOLDER/v2.0
# Optional aliases (used as a fallback if the AUTH_MICROSOFT_ENTRA_ID_* values above are unset):
AZURE_AD_CLIENT_ID=AZURE_AD_CLIENT_ID_PLACEHOLDER
AZURE_AD_CLIENT_SECRET=AZURE_AD_CLIENT_SECRET_PLACEHOLDER
AZURE_AD_TENANT_ID=AZURE_AD_TENANT_ID_PLACEHOLDER

# DEV-ONLY local login bypass. When "true" (and NODE_ENV is not production), a
# local email/password login form is enabled so the app is runnable without real
# Azure credentials. This is impossible to enable in production. Keep "false"
# unless you are developing locally.
AUTH_DEV_BYPASS=false

# Temporary deployed password login while Microsoft Entra ID is being configured.
# Keep disabled by default and remove/disable after SSO is live.
AUTH_TEMP_PASSWORD_LOGIN=false

# Local-dev seed password for seeded users (admin@example.com, sales@example.com,
# readonly@example.com). Local development ONLY - never set a real secret here.
SEED_ADMIN_PASSWORD=newl-dev-password

# OpenAI
OPENAI_API_KEY=OPENAI_API_KEY_PLACEHOLDER

# Apollo
APOLLO_API_KEY=APOLLO_API_KEY_PLACEHOLDER
APOLLO_MASTER_API=APOLLO_MASTER_API_PLACEHOLDER
APOLLO_USERNAME=APOLLO_USERNAME_PLACEHOLDER
APOLLO_PASSWORD=APOLLO_PASSWORD_PLACEHOLDER
APOLLO_PUBLIC_CONFIG_EXAMPLE={"baseUrl":"https://api.apollo.io","dryRun":true}

# TradeMining
TRADEMINING_USER=TRADEMINING_USER_PLACEHOLDER
TRADEMINING_PASSWORD=TRADEMINING_PASSWORD_PLACEHOLDER
TRADEMINING_PUBLIC_CONFIG_EXAMPLE={"lookbackDays":7,"ports":["PORT_KEY_PLACEHOLDER"]}

# Google Sheets legacy migration/export
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-service-account.json
NEWL_TRADE_MINING_SPREADSHEET_ID=GOOGLE_SHEETS_ID_PLACEHOLDER
NEWL_PROSPECTING_SHEET_ID=GOOGLE_SHEETS_ID_PLACEHOLDER
GOOGLE_SHEETS_PUBLIC_CONFIG_EXAMPLE={"spreadsheetId":"GOOGLE_SHEETS_ID_PLACEHOLDER","exportOnly":true}

# QuickBooks future module
QUICKBOOKS_CLIENT_ID=QUICKBOOKS_CLIENT_ID_PLACEHOLDER
QUICKBOOKS_CLIENT_SECRET=QUICKBOOKS_CLIENT_SECRET_PLACEHOLDER
QUICKBOOKS_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback
QUICKBOOKS_ENVIRONMENT=production

# UPS future module
# Preferred for deployed environments such as Vercel:
# JSON array of UPS account credential objects:
# [{"name":"US Account - G460D6","client_id":"...","client_secret":"...","shipper_number":"G460D6","country_code":"US"}]
UPS_RUNTIME_ACCOUNTS_JSON=
# Optional single-account fallback:
UPS_CLIENT_ID=UPS_CLIENT_ID_PLACEHOLDER
UPS_CLIENT_SECRET=UPS_CLIENT_SECRET_PLACEHOLDER
UPS_ACCOUNT_NUMBER=UPS_ACCOUNT_NUMBER_PLACEHOLDER
UPS_ACCOUNT_NAME=UPS_ACCOUNT_NAME_PLACEHOLDER
UPS_ACCOUNT_COUNTRY_CODE=US
# Local development helper for reusing an existing UPS account export without committing secrets.
UPS_DEV_ACCOUNTS_FILE=/absolute/path/to/accounts.json

# 7L future module
# Cloud/runtime helper for tenant-scoped 7L credentials matched by integration credential name.
# Example JSON:
# [{"name":"7L account","username":"user@example.com","password":"secret","baseUrl":"https://restapi.my7l.com"}]
SEVEN_L_RUNTIME_ACCOUNTS_JSON=
# Optional base64-encoded version of the same JSON payload above. Useful for hosts that prefer compact single-line secrets.
SEVEN_L_RUNTIME_ACCOUNTS_BASE64=
# Local development helper fallback for the same account array shape.
SEVEN_L_DEV_ACCOUNTS_FILE=/absolute/path/to/seven-l-accounts.json

# OpenClaw / legacy operations reporting
OPENCLAW_TOKEN=OPENCLAW_TOKEN_PLACEHOLDER
OPENCLAW_AGENT_RUN_TOKEN=OPENCLAW_AGENT_RUN_TOKEN_PLACEHOLDER

# Newl Apps ingestion API for VM/OpenClaw/n8n workers
# Use a long random value locally or in the deployment secret store. Do not commit real tokens.
INGESTION_API_TOKEN=INGESTION_API_TOKEN_PLACEHOLDER_CHANGE_ME
INGESTION_TENANT_SLUG=newl-group

# n8n legacy reference
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=N8N_API_KEY_PLACEHOLDER
