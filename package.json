{
  "name": "newl-apps",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev next dev",
    "build": "next build",
    "build:canonical-trademining-reference": "tsx scripts/build-canonical-trademining-reference.ts",
    "smoke:trademining": "tsx scripts/smoke-test-trademining.ts",
    "vercel-build": "tsx scripts/vercel-build.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "db:safety-check": "tsx scripts/db-safety-check.ts",
    "db:migrate:preview": "npm run db:safety-check -- --require-preview-db && npm run prisma:migrate:deploy",
    "db:migrate:production": "npm run db:safety-check -- --require-production-db && npm run prisma:migrate:deploy",
    "prisma:generate": "prisma generate",
    "postinstall": "npm run prisma:generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "verify:auth": "tsx scripts/verify-auth.ts",
    "verify:garland-teamship": "tsx scripts/verify-garland-teamship-review.ts",
    "verify:garland-teamship-phase2": "tsx scripts/garland-teamship-phase2-dry-run.ts",
    "smoke:teamship-phase2-manual": "tsx scripts/teamship-phase2-manual-smoke.ts",
    "worker:teamship-phase2": "tsx scripts/teamship-phase2-agent-worker.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "next": "^15.0.3",
    "next-auth": "^5.0.0-beta.31",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
