  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships                         Membership[]
  moduleAccess                        TenantModuleAccess[]
  rolePolicies                        TenantRolePolicy[]
  roleModuleAccess                    TenantRoleModuleAccess[]
  integrationCredentials              IntegrationCredential[]
  auditLogs                           AuditLog[]
  jobRuns                             AutomationJobRun[]
  companies                           Company[]
  importRecords                       TradeMiningImportRecord[]
  searchProfiles                      TradeMiningSearchProfile[]
  tradeMiningScoringConfig            TradeMiningScoringConfig?
  contacts                            Contact[]
  leads                               Lead[]
  contactOutreachDrafts               ContactOutreachDraft[]
  apolloCompanyMatches                ApolloCompanyMatch[]
  ltlBatchQuoteLanes                  LtlBatchQuoteLane[]
  assistantThreads                    AssistantChatThread[]
  assistantMessages                   AssistantChatMessage[]
  websiteInboundSubmissions           WebsiteInboundSubmission[]
  websiteGrowthOpportunities          WebsiteGrowthOpportunity[]
  websiteGrowthDataImports            WebsiteGrowthDataImport[]
  websiteGrowthMetrics                WebsiteGrowthMetric[]
  creditChecks                        CreditCheck[]
  assistantRuns                       AssistantRun[]
  assistantRetrievedSources           AssistantRetrievedSource[]
  assistantKnowledgeDocuments         AssistantKnowledgeDocument[]
  assistantKnowledgeChunks            AssistantKnowledgeChunk[]
  assistantMemories                   AssistantMemory[]
  assistantMailboxSyncStates          AssistantMailboxSyncState[]
  assistantAutomations                AssistantAutomation[]
  assistantAutomationRuns             AssistantAutomationRun[]
  shipmentDocumentRuns                ShipmentDocumentRun[]
  shipmentCarrierManifestRuns         ShipmentCarrierManifestRun[]
  teamshipReviewRuns                  TeamshipReviewRun[]
  teamshipReviewOrders                TeamshipReviewOrder[]
  teamshipDailySyncRuns               TeamshipDailySyncRun[]
  teamshipSyncedOrders                TeamshipSyncedOrder[]
  teamshipUpdateJobs                  TeamshipUpdateJob[]
  teamshipUpdateOrders                TeamshipUpdateOrder[]
  garlandProductDimensionObservations GarlandProductDimensionObservation[]
  cashflowCustomers                   CashflowCustomer[]
  cashflowCustomerAliases             CashflowCustomerAlias[]
  cashflowFiles                       CashflowFile[]
  cashflowCustomerInvoices            CashflowCustomerInvoice[]
  cashflowVendorBills                 CashflowVendorBill[]
  cashflowSnapshots                   CashflowCustomerSnapshot[]
  cashflowAlerts                      CashflowAlert[]
  cashflowFollowUps                   CashflowFollowUp[]
  cashflowAccountingLines             CashflowAccountingLine[]
  cashflowSettings                    CashflowSettings?
  oceanFreightAgents                  OceanFreightAgent[]
  oceanFreightAgentBranches           OceanFreightAgentBranch[]
  oceanFreightAgentContacts           OceanFreightAgentContact[]
  oceanFreightSourceEmails            OceanFreightSourceEmail[]
  oceanFreightSourceAttachments       OceanFreightSourceAttachment[]
  oceanFreightRateCandidates          OceanFreightRateCandidate[]
  oceanFreightRates                   OceanFreightRate[]
  invoiceAutomationDocuments          InvoiceAutomationDocument[]
  invoiceAutomationBatches            InvoiceAutomationBatch[]
  invoiceAutomationInvoices           InvoiceAutomationInvoice[]
  invoiceAutomationQuickBooksEntities InvoiceAutomationQuickBooksEntity[]
  invoiceAutomationEntityAliases      InvoiceAutomationEntityAlias[]
  invoiceAutomationCorrectionMemories InvoiceAutomationCorrectionMemory[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  // Used ONLY by the dev-only local credentials login path. Production logins
  // go through Microsoft Entra ID SSO and never set this field.
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships                 Membership[]
  accounts                    Account[]
  sessions                    Session[]
  assistantThreads            AssistantChatThread[]
  assistantRuns               AssistantRun[]
  assistantAutomations        AssistantAutomation[]
  assistantAutomationRuns     AssistantAutomationRun[]
  shipmentDocumentRuns        ShipmentDocumentRun[]
  shipmentCarrierManifestRuns ShipmentCarrierManifestRun[]
  teamshipReviewRuns          TeamshipReviewRun[]
  teamshipUpdateJobsCreated   TeamshipUpdateJob[] @relation("TeamshipUpdateJobCreatedBy")
  teamshipUpdateJobsApproved  TeamshipUpdateJob[] @relation("TeamshipUpdateJobApprovedBy")
}

// Auth.js (NextAuth) adapter models. Account links an external identity
// provider (Microsoft Entra ID) to a User. Sessions back the database session
// strategy. VerificationToken is required by the adapter contract.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id        String       @id @default(cuid())
  tenantId  String
  userId    String
  role      PlatformRole
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
}

model Module {
  id          String    @id @default(cuid())
  key         ModuleKey @unique
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenantAccess     TenantModuleAccess[]
  tenantRoleAccess TenantRoleModuleAccess[]
}

model TenantModuleAccess {
  id        String   @id @default(cuid())
  tenantId  String
  moduleId  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId, enabled])
}

model TenantRolePolicy {
  id        String       @id @default(cuid())
  tenantId  String
  role      PlatformRole
  canMutate Boolean
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role])
  @@index([tenantId, canMutate])
}

model TenantRoleModuleAccess {
  id        String       @id @default(cuid())
  tenantId  String
  role      PlatformRole
  moduleId  String
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role, moduleId])
  @@index([tenantId, role, enabled])
  @@index([tenantId, moduleId])
}

model WebsiteInboundSubmission {
  id          String               @id @default(cuid())
  tenantId    String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  status      WebsiteInboundStatus @default(NEW)
  formType    String
  source      String?
  pageUrl     String?
  name        String?
  email       String?
  company     String?
  phone       String?
  primaryNeed String?
  fields      Json

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, formType])
}

model WebsiteGrowthOpportunity {
  id                 String                         @id @default(cuid())
  tenantId           String
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  status             WebsiteGrowthOpportunityStatus @default(NEW)
  action             WebsiteGrowthAction
  topic              String
  primaryKeyword     String?
  targetPage         String?
  sourcePage         String?
  score              Int                            @default(0)
  confidence         String?
  reason             String
  recommendation     String
  supportingKeywords Json?
  evidence           Json?
  notes              String?
  approvedByUserId   String?
  publishedAt        DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([tenantId, action])
  @@index([tenantId, score])
  @@index([tenantId, updatedAt])
}

model WebsiteGrowthDataImport {
  id           String                    @id @default(cuid())
  tenantId     String
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  source       WebsiteGrowthDataSource
  status       WebsiteGrowthImportStatus @default(PENDING)
  fileName     String?
  rowCount     Int                       @default(0)
  summary      Json?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, source])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model WebsiteGrowthMetric {
  id              String                  @id @default(cuid())
  tenantId        String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  source          WebsiteGrowthDataSource
  page            String?
  query           String?
  country         String?
  device          String?
  dateRangeStart  DateTime?
  dateRangeEnd    DateTime?
  clicks          Int                     @default(0)
  impressions     Int                     @default(0)
  ctr             Float?
  position        Float?
  sessions        Int?
  engagedSessions Int?
  engagementRate  Float?
  eventCount      Int?
  leadCount       Int                     @default(0)
  raw             Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, source])
  @@index([tenantId, page])
  @@index([tenantId, query])
  @@index([tenantId, dateRangeStart])
}

model CreditCheck {
  id                   String            @id @default(cuid())
  tenantId             String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  status               CreditCheckStatus @default(NEW)
  source               String?
  pageUrl              String?
  legalCompanyName     String?
  operatingName        String?
  company              String?
  mainPhone            String?
  primaryContactName   String?
  primaryContactEmail  String?
  accountsPayableEmail String?
  requestedCreditLimit String?
  approvedCreditLimit  String?
  services             Json?
  tradeReferences      Json?
  fields               Json
  referencesContacted  Boolean           @default(false)
  referenceNotes       String?
  internalNotes        String?
  reviewedByUserId     String?
  approvedByUserId     String?
  approvedAt           DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, company])
}

model ShipmentDocumentRun {
  id                       String    @id @default(cuid())
  tenantId                 String
  workflowKey              String    @default("GARLAND_CANADA")
  documentLabel            String
  shipmentDate             DateTime
  recipientEmail           String?
  sourceBolFileName        String?
  sourcePickTicketFileName String?
  outputBolFileName        String
  outputPickTicketFileName String
  bolPageCount             Int
  pickTicketPageCount      Int
  bolAiFallbackPageCount   Int       @default(0)
  pickAiFallbackPageCount  Int       @default(0)
  bolPsNumbers             Json
  pickPsNumbers            Json
  searchText               String
  bolPdfBytes              Bytes
  pickTicketPdfBytes       Bytes
  bolPdfUploadComplete     Boolean   @default(true)
  pickPdfUploadComplete    Boolean   @default(true)
  createdByUserId          String?
  deletedAt                DateTime?
  deletedByUserId          String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation(fields: [createdByUserId], references: [id], onDelete: NoAction)

  @@index([tenantId, workflowKey, shipmentDate])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
}

model ShipmentCarrierManifestRun {
  id                     String    @id @default(cuid())
  tenantId               String
  workflowKey            String    @default("GARLAND_CARRIER_MANIFEST")
  documentLabel          String
  shipmentDate           DateTime
  sourceBolFileName      String?
  carrierCounts          Json
  manifestRows           Json
  midlandFileName        String?
  midlandWorkbookBytes   Bytes?
  speedyFileName         String?
  speedyWorkbookBytes    Bytes?
  suretrackFileName      String?
  suretrackWorkbookBytes Bytes?
  signedCopyFileName     String?
  signedCopyContentType  String?
  signedCopyBytes        Bytes?
  signedCopyUploadedAt   DateTime?
  createdByUserId        String?
  deletedAt              DateTime?
  deletedByUserId        String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation(fields: [createdByUserId], references: [id], onDelete: NoAction)

  @@index([tenantId, workflowKey, shipmentDate])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
}

model TeamshipReviewRun {
  id                    String    @id @default(cuid())
  tenantId              String
  workflowKey           String    @default("GARLAND_TEAMSHIP_REVIEW")
  documentLabel         String
  shipmentDate          DateTime
  sourcePdfFileName     String?
  pdfOrderCount         Int
  teamshipMatchedCount  Int
  passedCount           Int
  failedCount           Int
  missingTeamshipCount  Int
  pendingTeamshipCount  Int
  noPdfCount            Int       @default(0)
  alertDigestOrderCount Int       @default(0)
  summary               Json
  extractedOrders       Json
  reviewResponse        Json
  searchText            String
  createdByUserId       String?
  deletedAt             DateTime?
  deletedByUserId       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?                 @relation(fields: [createdByUserId], references: [id], onDelete: NoAction)
  orders    TeamshipReviewOrder[]

  @@index([tenantId, workflowKey, shipmentDate])
  @@index([tenantId, createdAt])
  @@index([tenantId, searchText])
  @@index([tenantId, deletedAt])
}

model TeamshipReviewOrder {
  id              String   @id @default(cuid())
  tenantId        String
  runId           String
  psNumber        String
  srNumber        String
  status          String
  teamshipOrderId String?
  teamshipUrl     String?
  carrier         String?
  shipToName      String?
  city            String?
  state           String?
  shipToPo        String?
  pageNumbers     Json
  pdfOrder        Json
  review          Json
  mismatchCount   Int      @default(0)
  createdAt       DateTime @default(now())

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  run    TeamshipReviewRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([tenantId, runId])
  @@index([tenantId, srNumber])
  @@index([tenantId, psNumber])
  @@index([tenantId, status])
}

model TeamshipDailySyncRun {
  id              String    @id @default(cuid())
  tenantId        String
  shipmentDate    DateTime
  triggerSource   String
  status          String
  fetchedCount    Int       @default(0)
  insertedCount   Int       @default(0)
  updatedCount    Int       @default(0)
  skippedCount    Int       @default(0)
  errorMessage    String?
  createdByUserId String?
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, shipmentDate])
  @@index([tenantId, triggerSource, startedAt])
  @@index([tenantId, status])
}

model TeamshipSyncedOrder {
  id              String   @id @default(cuid())
  tenantId        String
  syncKey         String
  shipmentDate    DateTime
  srNumber        String?
  teamshipOrderId String?
  teamshipUrl     String?
  carrier         String?
  shipToName      String?
  city            String?
  state           String?
  rawOrder        Json
  firstSyncedAt   DateTime @default(now())
  lastSyncedAt    DateTime @default(now())
  syncCount       Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, syncKey])
  @@index([tenantId, shipmentDate])
  @@index([tenantId, srNumber])
  @@index([tenantId, teamshipOrderId])
  @@index([tenantId, lastSyncedAt])
}

model GarlandProductDimensionObservation {
  id                    String   @id @default(cuid())
  tenantId              String
  observationKey        String
  sku                   String
  source                String   @default("TEAMSHIP_PALLET")
  sourceTeamshipOrderId String?
  sourceSrNumber        String?
  carrier               String?
  commodity             String?
  quantity              Float?
  lengthIn              Float
  widthIn               Float
  heightIn              Float
  weightLb              Float
  weightUnit            String?  @default("lbs")
  observedAt            DateTime @default(now())
  createdAt             DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, observationKey])
