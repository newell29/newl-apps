generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  ADMIN
  MANAGER
  SALES
  OPERATIONS
  FINANCE
  READ_ONLY
}

enum ModuleKey {
  ASSISTANT
  LEAD_GEN
  UPS_TOOLS
  LTL_RATE_PORTAL
  TRANSIT_LOOKUP
  INVOICE_VERIFICATION
  QUICKBOOKS_POSTING
}

enum IntegrationProvider {
  APOLLO
  TRADEMINING
  GOOGLE_SHEETS
  MICROSOFT_GRAPH
  QUICKBOOKS
  UPS
  SEVEN_L
  TMS
  WMS
  OPENCLAW
  OPENAI
  LOCAL_LLM
}

enum IntegrationStatus {
  ACTIVE
  DISABLED
  ERROR
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCESS
  ERROR
  CANCELLED
}

enum LeadPipelineStage {
  NEW
  RESEARCHING
  ENRICHED
  QUALIFIED
  CONTACTED
  REPLIED
  MEETING_BOOKED
  QUOTED
  WON
  LOST
  DISQUALIFIED
}

enum CandidateStatus {
  NEW
  REVIEWING
  APPROVED_FOR_PIPELINE
  REJECTED
  DISQUALIFIED
}

enum ContactSource {
  MANUAL
  APOLLO
  IMPORT
  UNKNOWN
}

enum ContactStatus {
  NEW
  REVIEWING
  APPROVED
  REJECTED
  DO_NOT_CONTACT
}

enum ContactTier {
  UNRANKED
  TIER_1
  TIER_2
  TIER_3
}

enum ApolloStatus {
  NOT_STARTED
  ENRICHED
  NOT_FOUND
  ERROR
}

enum ApolloCompanyMatchClassification {
  DIRECT_COMPANY
  MATCH_QUALITY_REVIEW
  LOGISTICS_PROVIDER
  NO_MATCH
}

enum SequenceStatus {
  NOT_STARTED
  READY
  ENROLLED
  PAUSED
  REPLIED
  BOUNCED
  FINISHED
}

enum ReplyStatus {
  NO_REPLY
  REPLIED
  POSITIVE
  NEGATIVE
  MEETING_BOOKED
  OUT_OF_OFFICE
}

enum ContactOutreachDraftStatus {
  DRAFT
  AVAILABLE
  EDITED
  APPROVED
  PUSHED_TO_APOLLO
}

enum ContactOutreachDraftSource {
  MOCK_AI
  MANUAL
  TEMPLATE
  UNKNOWN
}

enum AssistantMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum AssistantSourceKind {
  COMPANY
  CONTACT
  LEAD
  TRADEMINING_RECORD
  RATE_TOOL
  EMAIL
  ONEDRIVE_FILE
  TMS_RECORD
  WMS_RECORD
  INTEGRATION
  MANUAL
  OTHER
}

enum AssistantMemoryKind {
  CUSTOMER_PROFILE
  SERVICE_CAPABILITY
  SALES_OPPORTUNITY
  OPERATIONAL_RISK
  RATE_CONTEXT
  USER_PREFERENCE
  TENANT_FACT
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships            Membership[]
  moduleAccess           TenantModuleAccess[]
  rolePolicies           TenantRolePolicy[]
  roleModuleAccess       TenantRoleModuleAccess[]
  integrationCredentials IntegrationCredential[]
  auditLogs              AuditLog[]
  jobRuns                AutomationJobRun[]
  companies              Company[]
  importRecords          TradeMiningImportRecord[]
  searchProfiles         TradeMiningSearchProfile[]
  tradeMiningScoringConfig TradeMiningScoringConfig?
  contacts               Contact[]
  leads                  Lead[]
  contactOutreachDrafts  ContactOutreachDraft[]
  apolloCompanyMatches   ApolloCompanyMatch[]
  ltlBatchQuoteLanes     LtlBatchQuoteLane[]
  assistantThreads       AssistantChatThread[]
  assistantMessages      AssistantChatMessage[]
  assistantRuns          AssistantRun[]
  assistantRetrievedSources AssistantRetrievedSource[]
  assistantKnowledgeDocuments AssistantKnowledgeDocument[]
  assistantKnowledgeChunks AssistantKnowledgeChunk[]
  assistantMemories      AssistantMemory[]
  assistantAutomations   AssistantAutomation[]
  assistantAutomationRuns AssistantAutomationRun[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  // Used ONLY by the dev-only local credentials login path. Production logins
  // go through Microsoft Entra ID SSO and never set this field.
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships Membership[]
  accounts    Account[]
  sessions    Session[]
  assistantThreads AssistantChatThread[]
  assistantRuns    AssistantRun[]
  assistantAutomations AssistantAutomation[]
  assistantAutomationRuns AssistantAutomationRun[]
}

// Auth.js (NextAuth) adapter models. Account links an external identity
// provider (Microsoft Entra ID) to a User. Sessions back the database session
// strategy. VerificationToken is required by the adapter contract.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id        String       @id @default(cuid())
  tenantId  String
  userId    String
  role      PlatformRole
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
}

model Module {
  id          String    @id @default(cuid())
  key         ModuleKey @unique
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenantAccess     TenantModuleAccess[]
  tenantRoleAccess TenantRoleModuleAccess[]
}

model TenantModuleAccess {
  id        String   @id @default(cuid())
  tenantId  String
  moduleId  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId, enabled])
}

model TenantRolePolicy {
  id        String       @id @default(cuid())
  tenantId  String
  role      PlatformRole
  canMutate Boolean
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role])
  @@index([tenantId, canMutate])
}

model TenantRoleModuleAccess {
  id        String       @id @default(cuid())
  tenantId  String
  role      PlatformRole
  moduleId  String
  enabled   Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, role, moduleId])
  @@index([tenantId, role, enabled])
  @@index([tenantId, moduleId])
}

model IntegrationCredential {
  id           String              @id @default(cuid())
  tenantId     String
  provider     IntegrationProvider
  name         String
  status       IntegrationStatus   @default(DISABLED)
  publicConfig Json?
  secretRef    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, provider])
  @@index([tenantId, status])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

model AutomationJobRun {
  id           String    @id @default(cuid())
  tenantId     String
  jobType      String
  status       JobStatus
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  input        Json?
  output       Json?
  errorMessage String?
  createdAt    DateTime  @default(now())

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ltlBatchQuoteLanes LtlBatchQuoteLane[]

  @@index([tenantId, jobType, startedAt])
  @@index([tenantId, status])
}

model LtlBatchQuoteLane {
  id               String    @id @default(cuid())
  tenantId         String
  jobRunId         String
  laneIndex        Int
  customerReference String
  quoteCount       Int       @default(0)
  errorCount       Int       @default(0)
  requestJson      Json
  quotesJson       Json?
  errorsJson       Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobRun AutomationJobRun @relation(fields: [jobRunId], references: [id], onDelete: Cascade)

  @@unique([jobRunId, laneIndex])
  @@index([tenantId, jobRunId])
  @@index([tenantId, createdAt])
}

model Company {
  id                       String          @id @default(cuid())
  tenantId                 String
  name                     String
  normalizedName           String
  domain                   String?
  linkedinUrl              String?
  source                   String?
  primaryIndustry          String?
  secondaryIndustry        String?
  industryConfidence       Int?
  industrySource           String?
  priorityScore            Int             @default(0)
  candidateStatus          CandidateStatus @default(NEW)
  candidateStatusUpdatedAt DateTime?
  candidateStatusReason    String?
  apolloOrganizationId     String?
  doNotProspect            Boolean         @default(false)
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  tenant                Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importRecords         TradeMiningImportRecord[]
  contacts              Contact[]
  leads                 Lead[]
  contactOutreachDrafts ContactOutreachDraft[]
  apolloCompanyMatches  ApolloCompanyMatch[]

  @@unique([tenantId, id])
  @@unique([tenantId, normalizedName])
  @@index([tenantId, candidateStatus])
  @@index([tenantId, candidateStatus, priorityScore])
  @@index([tenantId, priorityScore])
  @@index([tenantId, domain])
  @@index([tenantId, linkedinUrl])
  @@index([tenantId, primaryIndustry])
}

model ApolloCompanyMatch {
  id                     String                           @id @default(cuid())
  tenantId               String
  companyId              String
  apolloOrganizationId   String?
  apolloCompanyName      String?
  apolloDomain           String?
  apolloLinkedinUrl      String?
  score                  Int                              @default(0)
  classification         ApolloCompanyMatchClassification
  nameMatchType          String?
  domainMatch            Boolean                          @default(false)
  logisticsProviderMatch Boolean                          @default(false)
  branchLocationMatch    Boolean                          @default(false)
  matchReason            String?
  queryJson              Json?
  rawJson                Json?
  reviewedAt             DateTime?
  reviewedByUserId       String?
  createdAt              DateTime                         @default(now())
  updatedAt              DateTime                         @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [tenantId, companyId], references: [tenantId, id], onDelete: Cascade)

  @@index([tenantId, companyId, createdAt])
  @@index([tenantId, classification])
  @@index([tenantId, apolloOrganizationId])
}

model TradeMiningSearchProfile {
  id                 String    @id @default(cuid())
  tenantId           String
  name               String
  description        String?
  enabled            Boolean   @default(true)
  contactCadenceConfig Json?
  destinationMarkets Json
  destinationPorts   Json?
  originPorts        Json?
  shipFromPorts      Json?
  originCountries    Json?
  productKeywords    Json?
  hsCodes            Json?
  allowedCompanyIdentityRoles Json?
  excludedCompanyKeywords Json?
  lookbackWindowDays Int       @default(90)
  minShipmentCount   Int       @default(1)
  minShipmentVolume  Decimal?  @db.Decimal(12, 2)
  scheduleFrequency  String    @default("daily")
  scheduleTimezone   String    @default("America/Toronto")
  scheduleMetadata   Json?
  priorityWeight     Int       @default(50)
  lastRunAt          DateTime?
  lastRunStatus      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId, enabled])
  @@index([tenantId, priorityWeight])
  @@index([tenantId, scheduleFrequency])
}

model TradeMiningScoringConfig {
  id                               String    @id @default(cuid())
  tenantId                         String    @unique
  recentWindowDays                 Int       @default(30)
  comparisonWindowDays             Int       @default(30)
  lookbackWindowDays               Int       @default(90)
  momentumWeight                   Int       @default(30)
  marketFitWeight                  Int       @default(20)
  industryFitWeight                Int       @default(15)
  companySizeWeight                Int       @default(15)
  roleWeight                       Int       @default(10)
  confidenceWeight                 Int       @default(5)
  workflowWeight                   Int       @default(5)
  preferredOriginCountries         Json?
  penalizedOriginCountries         Json?
  preferredOriginPorts             Json?
  penalizedOriginPorts             Json?
  preferredDestinationMarkets      Json?
  penalizedDestinationMarkets      Json?
  preferredIndustryKeywords        Json?
  penalizedIndustryKeywords        Json?
  preferredHsCodePrefixes          Json?
  penalizedHsCodePrefixes          Json?
  oversizeTeuThreshold             Decimal?  @db.Decimal(12, 2)
  oversizeShipmentCount30dThreshold Int?
  oversizePenalty                  Int       @default(10)
  midMarketTeuMin                  Decimal?  @db.Decimal(12, 2)
  midMarketTeuMax                  Decimal?  @db.Decimal(12, 2)
  midMarketBoost                   Int       @default(6)
  contactDecisionMakerWeight       Int       @default(20)
  contactManagerWeight             Int       @default(12)
  contactLogisticsDepartmentWeight Int       @default(15)
  contactWeakFunctionPenalty       Int       @default(6)
  contactCompanyContextWeight      Int       @default(15)
  contactEmailWeight               Int       @default(6)
  contactLinkedinWeight            Int       @default(4)
  contactPhoneWeight               Int       @default(2)
  contactPrimaryContactBoost       Int       @default(6)
  contactApprovedStatusBoost       Int       @default(3)
  contactReviewingStatusBoost      Int       @default(2)
  contactTier1Threshold            Int       @default(78)
  contactTier2Threshold            Int       @default(58)
  contactTier3Threshold            Int       @default(36)
  preferredContactTitleKeywords    Json?
  penalizedContactTitleKeywords    Json?
  preferredContactDepartments      Json?
  penalizedContactDepartments      Json?
  aiClassificationEnabled          Boolean   @default(false)
  aiModel                          String?
  createdAt                        DateTime  @default(now())
  updatedAt                        DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TradeMiningImportRecord {
  id                 String    @id @default(cuid())
  tenantId           String
  companyId          String?
  rawRecordKey       String
  sourcePort         String?
  arrivalDate        DateTime?
  importerName       String?
  consigneeName      String?
  shipperName        String?
  destinationCity    String?
  destinationState   String?
  originCountry      String?
  productDescription String?
  rawJson            Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [tenantId, companyId], references: [tenantId, id], onDelete: NoAction)

  @@unique([tenantId, rawRecordKey])
  @@index([tenantId, arrivalDate])
  @@index([tenantId, sourcePort])
}

model Contact {
  id                           String         @id @default(cuid())
  tenantId                     String
  companyId                    String
  firstName                    String?
  lastName                     String?
  fullName                     String
  title                        String?
  department                   String?
  seniority                    String?
  email                        String?
  phone                        String?
  linkedinUrl                  String?
  source                       ContactSource  @default(UNKNOWN)
  contactStatus                ContactStatus  @default(NEW)
  contactScore                 Int            @default(0)
  contactTier                  ContactTier    @default(UNRANKED)
  apolloContactId              String?
  apolloPersonId               String?
  apolloStatus                 ApolloStatus   @default(NOT_STARTED)
  sequenceStatus               SequenceStatus @default(NOT_STARTED)
  replyStatus                  ReplyStatus    @default(NO_REPLY)
  recommendedSequenceName      String?
  recommendedSequenceId        String?
  selectedSequenceName         String?
  selectedSequenceId           String?
  sequenceRecommendationReason String?
  sequenceOverrideReason       String?
  sequenceManuallyOverridden   Boolean        @default(false)
  lastTouchAt                  DateTime?
  lastReplyAt                  DateTime?
  assignedRep                  String?
  rawJson                      Json?
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company        Company                @relation(fields: [tenantId, companyId], references: [tenantId, id], onDelete: Cascade)
  leads          Lead[]
  outreachDrafts ContactOutreachDraft[]

  @@unique([tenantId, id])
  @@unique([tenantId, companyId, id])
  @@index([tenantId, email])
  @@index([tenantId, linkedinUrl])
  @@index([tenantId, apolloContactId])
  @@index([tenantId, apolloPersonId])
  @@index([tenantId, companyId])
  @@index([tenantId, companyId, contactStatus])
  @@index([tenantId, contactStatus])
  @@index([tenantId, contactScore])
  @@index([tenantId, contactTier])
  @@index([tenantId, apolloStatus])
  @@index([tenantId, sequenceStatus])
  @@index([tenantId, selectedSequenceId])
  @@index([tenantId, sequenceManuallyOverridden])
  @@index([tenantId, replyStatus])
  @@index([tenantId, source])
  @@index([tenantId, assignedRep])
}

model ContactOutreachDraft {
  id                   String                     @id @default(cuid())
  tenantId             String
  contactId            String
  companyId            String
  leadId               String?
  sequenceName         String
  sequenceId           String?
  subject              String
  body                 String
  status               ContactOutreachDraftStatus @default(AVAILABLE)
  source               ContactOutreachDraftSource @default(UNKNOWN)
  aiGenerated          Boolean                    @default(false)
  personalizationNotes String?
  rawInputs            Json?
  rawJson              Json?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  editedAt             DateTime?
  approvedAt           DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [tenantId, companyId, contactId], references: [tenantId, companyId, id], onDelete: Cascade)
  company Company @relation(fields: [tenantId, companyId], references: [tenantId, id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [tenantId, companyId, leadId], references: [tenantId, companyId, id], onDelete: NoAction)

  @@unique([tenantId, contactId, sequenceName])
  @@index([tenantId, companyId])
  @@index([tenantId, contactId])
  @@index([tenantId, status])
  @@index([tenantId, source])
  @@index([tenantId, sequenceId])
}

model Lead {
  id          String            @id @default(cuid())
  tenantId    String
  companyId   String
  contactId   String?
  stage       LeadPipelineStage @default(NEW)
  ownerUserId String?
  score       Int               @default(0)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company        Company                @relation(fields: [tenantId, companyId], references: [tenantId, id], onDelete: Cascade)
  contact        Contact?               @relation(fields: [tenantId, companyId, contactId], references: [tenantId, companyId, id], onDelete: NoAction)
  outreachDrafts ContactOutreachDraft[]

  @@unique([tenantId, companyId])
  @@unique([tenantId, companyId, id])
  @@index([tenantId, stage])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, score])
}

model AssistantChatThread {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String?
  title         String
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime?

  tenant   Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages AssistantChatMessage[]
  runs     AssistantRun[]

  @@unique([tenantId, id])
  @@index([tenantId, userId, updatedAt])
  @@index([tenantId, status, updatedAt])
}

model AssistantChatMessage {
  id        String               @id @default(cuid())
  tenantId  String
  threadId  String
  role      AssistantMessageRole
  content   String
  metadata  Json?
  createdAt DateTime             @default(now())

  tenant Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread AssistantChatThread @relation(fields: [tenantId, threadId], references: [tenantId, id], onDelete: Cascade)
  runs   AssistantRun[]

  @@index([tenantId, threadId, createdAt])
  @@index([tenantId, role])
}

model AssistantRun {
  id             String    @id @default(cuid())
  tenantId       String
  threadId       String?
  messageId      String?
  userId         String?
  provider       String
  model          String?
  status         JobStatus
  intent         String?
  inputTokens    Int?
  outputTokens   Int?
  estimatedCost  Decimal?  @db.Decimal(12, 6)
  metadata       Json?
  errorMessage   String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  tenant           Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  thread           AssistantChatThread?       @relation(fields: [tenantId, threadId], references: [tenantId, id], onDelete: Cascade)
  message          AssistantChatMessage?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  user             User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  retrievedSources AssistantRetrievedSource[]
  memories         AssistantMemory[]

  @@unique([tenantId, id])
  @@index([tenantId, status, startedAt])
  @@index([tenantId, userId, startedAt])
  @@index([tenantId, threadId, startedAt])
}

model AssistantRetrievedSource {
  id         String              @id @default(cuid())
  tenantId   String
  runId      String
  sourceKind AssistantSourceKind
  sourceId   String?
  title      String
  excerpt    String?
  score      Decimal?            @db.Decimal(8, 4)
  metadata   Json?
  createdAt  DateTime            @default(now())

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  run    AssistantRun @relation(fields: [tenantId, runId], references: [tenantId, id], onDelete: Cascade)

  @@index([tenantId, runId])
  @@index([tenantId, sourceKind, sourceId])
}

model AssistantKnowledgeDocument {
  id              String              @id @default(cuid())
  tenantId        String
  sourceKind      AssistantSourceKind
  sourceSystem    String
  externalId      String?
  title           String
  canonicalUrl    String?
  contentHash     String?
  sourceUpdatedAt DateTime?
  indexedAt       DateTime?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chunks   AssistantKnowledgeChunk[]
  memories AssistantMemory[]

  @@unique([tenantId, id])
  @@unique([tenantId, sourceSystem, externalId])
  @@index([tenantId, sourceKind])
  @@index([tenantId, sourceSystem])
  @@index([tenantId, indexedAt])
}

model AssistantKnowledgeChunk {
  id             String   @id @default(cuid())
  tenantId       String
  documentId     String
  chunkIndex     Int
  contentText    String
  contentSummary String?
  embeddingRef   String?
  tokenCount     Int?
  metadata       Json?
  createdAt      DateTime @default(now())

  tenant   Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document AssistantKnowledgeDocument @relation(fields: [tenantId, documentId], references: [tenantId, id], onDelete: Cascade)

  @@unique([tenantId, documentId, chunkIndex])
  @@index([tenantId, documentId])
  @@index([tenantId, embeddingRef])
}

model AssistantMemory {
  id               String              @id @default(cuid())
  tenantId         String
  kind             AssistantMemoryKind
  subjectType      String
  subjectId        String?
  title            String
  summary          String
  confidence       Int                 @default(50)
  status           String              @default("ACTIVE")
  sourceDocumentId String?
  sourceRunId      String?
  lastObservedAt   DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant         Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceDocument AssistantKnowledgeDocument? @relation(fields: [tenantId, sourceDocumentId], references: [tenantId, id], onDelete: NoAction)
  sourceRun      AssistantRun?               @relation(fields: [tenantId, sourceRunId], references: [tenantId, id], onDelete: NoAction)

  @@index([tenantId, kind])
  @@index([tenantId, subjectType, subjectId])
  @@index([tenantId, status, updatedAt])
}

model AssistantAutomation {
  id                String   @id @default(cuid())
  tenantId          String
  userId            String
  name              String
  prompt            String
  scheduleType      String
  scheduleTime      String
  scheduleTimezone  String
  status            String   @default("ACTIVE")
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  lastResultSummary String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs   AssistantAutomationRun[]

  @@unique([tenantId, id])
  @@index([tenantId, userId, status, updatedAt])
}

model AssistantAutomationRun {
  id             String    @id @default(cuid())
  tenantId       String
  automationId   String
  userId         String
  status         JobStatus
  promptSnapshot String
  responseText   String
  sourceCount    Int       @default(0)
  metadata       Json?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  automation AssistantAutomation @relation(fields: [tenantId, automationId], references: [tenantId, id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, automationId, startedAt])
  @@index([tenantId, userId, startedAt])
}
