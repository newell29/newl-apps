  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant         Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceDocument AssistantKnowledgeDocument? @relation(fields: [tenantId, sourceDocumentId], references: [tenantId, id], onDelete: NoAction)
  sourceRun      AssistantRun?               @relation(fields: [tenantId, sourceRunId], references: [tenantId, id], onDelete: NoAction)

  @@index([tenantId, kind])
  @@index([tenantId, subjectType, subjectId])
  @@index([tenantId, status, updatedAt])
}

model AssistantMailboxSyncState {
  id                        String    @id @default(cuid())
  tenantId                  String
  mailboxAddress            String
  sourceSystem              String    @default("MICROSOFT_GRAPH_MAIL")
  status                    JobStatus @default(QUEUED)
  lastStartedAt             DateTime?
  lastFinishedAt            DateTime?
  lastSuccessfulSyncAt      DateTime?
  lastSuccessfulReceivedAt  DateTime?
  lastAttemptedLookbackDays Int?
  lastAttemptedMaxMessages  Int?
  lastMessageCount          Int       @default(0)
  totalMessageCount         Int       @default(0)
  lastError                 String?
  metadata                  Json?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sourceSystem, mailboxAddress])
  @@index([tenantId, status, updatedAt])
  @@index([tenantId, mailboxAddress])
}

model AssistantAutomation {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  name              String
  prompt            String
  scheduleType      String
  scheduleTime      String
  scheduleTimezone  String
  status            String    @default("ACTIVE")
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  lastResultSummary String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs   AssistantAutomationRun[]

  @@unique([tenantId, id])
  @@index([tenantId, userId, status, updatedAt])
}

model AssistantAutomationRun {
  id             String    @id @default(cuid())
  tenantId       String
  automationId   String
  userId         String
  status         JobStatus
  promptSnapshot String
  responseText   String
  sourceCount    Int       @default(0)
  metadata       Json?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  automation AssistantAutomation @relation(fields: [tenantId, automationId], references: [tenantId, id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, automationId, startedAt])
  @@index([tenantId, userId, startedAt])
}
