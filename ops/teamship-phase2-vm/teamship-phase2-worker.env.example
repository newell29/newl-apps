# Copy this file to ~/newl-apps/.env.teamship-phase2-worker on the VM.
# Do not commit the real token or credentials.

NEWL_APPS_BASE_URL=https://newl-apps.vercel.app
NEWL_AGENT_TOKEN=replace-with-production-ingestion-token
TEAMSHIP_AGENT_MODE=live-api

# Optional rollout allowlist. Use comma-separated SRs for limited testing.
# Use "*" only when the VM should process every approved Newl Apps job.
# Leave unset/blank to block live jobs until an explicit rollout choice is made.
TEAMSHIP_LIVE_ALLOWLIST_SR_NUMBERS=*

# Use the Chrome install on the VM.
TEAMSHIP_BROWSER_EXECUTABLE_PATH=/usr/bin/google-chrome
TEAMSHIP_BROWSER_HEADED=true
TEAMSHIP_BROWSER_SLOW_MO_MS=350
TEAMSHIP_BROWSER_PAUSE_ON_ERROR=true

# Set this if the VM browser needs a display for headed Chrome.
# Common VNC values are :0 or :1. The installer fills this from the current shell when available.
# DISPLAY=:1
# XAUTHORITY=/home/newln8n/.Xauthority

# Optional toggles. Field updates stay opt-in for browser mode.
# In live-api mode, BOL weight cleanup runs after successful API updates unless disabled.
# TEAMSHIP_BROWSER_FIELD_UPDATES=true
# TEAMSHIP_BROWSER_BOL_CLEANUP=false
# TEAMSHIP_BROWSER_DISABLE_BOL_CLEANUP=true
